// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users Table
model User {
  id    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email String  @unique
  passwordHash String @map("password_hash")
  firstName String? @map("first_name")
  lastName String? @map("last_name")
  avatarUrl String? @map("avatar_url")
  emailVerified Boolean @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  phone String?
  bio String?
  
  preferences UserPreference?
  categories Category[]
  transactions Transaction[]
  activities Activity[]
  reminders Reminder[]
  reminderOccurrences ReminderOccurrence[]
  insights Insight[]
  pushSubscriptions PushSubscription[]
  activityLogs ActivityLog[]
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  
  @@index([email])
  @@index([createdAt])
  @@map("users")
}

// User Preferences Table
model UserPreference {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid
  theme String @default("light") // light, dark, auto
  language String @default("en")
  currency String @default("USD")
  timezone String @default("UTC")
  notificationsEnabled Boolean @default(true) @map("notifications_enabled")
  pushNotificationsEnabled Boolean @default(true) @map("push_notifications_enabled")
  emailDigestEnabled Boolean @default(true) @map("email_digest_enabled")
  digestFrequency String @default("weekly") @map("digest_frequency") // daily, weekly, monthly
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@map("user_preferences")
}

// Categories Table
model Category {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  name String
  description String?
  icon String? // emoji or icon name
  color String? // hex color
  type String // income, expense
  isDefault Boolean @default(false) @map("is_default")
  sortOrder Int? @map("sort_order")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  
  @@unique([userId, name])
  @@index([userId])
  @@index([type])
  @@map("categories")
}

// Transactions Table
model Transaction {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid
  title String
  description String?
  amount Decimal @db.Decimal(15, 2)
  type String // income, expense
  date DateTime @db.Date
  time DateTime? @db.Time
  paymentMethod String? @map("payment_method")
  receiptImageUrl String? @map("receipt_image_url")
  tags String[]
  metadata Json?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  
  @@index([userId])
  @@index([categoryId])
  @@index([date])
  @@index([type])
  @@index([userId, date(sort: Desc)])
  @@map("transactions")
}

// Activities Table
model Activity {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  title String
  description String?
  category String?
  startTime DateTime @map("start_time")
  endTime DateTime? @map("end_time")
  durationMinutes Int? @map("duration_minutes")
  mood String? // angry, sad, neutral, happy, excellent
  rating Int? // 1-5 scale
  location String?
  participants String[]
  tags String[]
  imageUrls String[] @map("image_urls")
  metadata Json?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  
  @@index([userId])
  @@index([startTime])
  @@index([category])
  @@index([mood])
  @@index([userId, startTime(sort: Desc)])
  @@map("activities")
}

// Reminders Table
model Reminder {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  title String
  description String?
  dueDate DateTime? @map("due_date") @db.Date
  dueTime DateTime? @map("due_time") @db.Time
  dueDatetime DateTime? @map("due_datetime")
  category String? // bill, habit, appointment, task, etc
  priority String @default("medium") // low, medium, high
  status String @default("pending") // pending, completed, cancelled
  
  isRecurring Boolean @default(false) @map("is_recurring")
  recurrencePattern String? @map("recurrence_pattern") // daily, weekly, monthly, yearly
  recurrenceCustomRule String? @map("recurrence_custom_rule") // iCalendar RRULE
  recurrenceEndDate DateTime? @map("recurrence_end_date") @db.Date
  recurrenceOccurrences Int? @map("recurrence_occurrences")
  
  notifyDaysBefore Int? @map("notify_days_before")
  notifyHoursBefore Int? @map("notify_hours_before")
  notifyTimes Int[] @default([]) @map("notify_times")
  
  tags String[]
  metadata Json?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  occurrences ReminderOccurrence[]
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  
  @@index([userId])
  @@index([dueDatetime])
  @@index([status])
  @@index([isRecurring])
  @@map("reminders")
}

// Reminder Occurrences Table (for recurring reminders)
model ReminderOccurrence {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reminderId String @map("reminder_id") @db.Uuid
  userId String @map("user_id") @db.Uuid
  scheduledDatetime DateTime @map("scheduled_datetime")
  status String @default("pending") // pending, completed, skipped
  notifiedAt DateTime? @map("notified_at")
  completedAt DateTime? @map("completed_at")
  notes String?
  
  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@index([reminderId])
  @@index([userId])
  @@index([scheduledDatetime])
  @@index([status])
  @@map("reminder_occurrences")
}

// Insights Table
model Insight {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  date DateTime @db.Date
  type String // daily, weekly, monthly
  periodStart DateTime? @map("period_start") @db.Date
  periodEnd DateTime? @map("period_end") @db.Date
  
  totalIncome Decimal? @map("total_income") @db.Decimal(15, 2)
  totalExpense Decimal? @map("total_expense") @db.Decimal(15, 2)
  topExpenses Json? @map("top_expenses")
  spendingByCategory Json? @map("spending_by_category")
  budgetStatus Json? @map("budget_status")
  
  totalActivities Int? @map("total_activities")
  activitiesByCategory Json? @map("activities_by_category")
  moodSummary Json? @map("mood_summary")
  averageActivityRating Decimal? @map("average_activity_rating") @db.Decimal(3, 2)
  mostActiveHour DateTime? @map("most_active_hour") @db.Time
  
  habitCompletionRate Decimal? @map("habit_completion_rate") @db.Decimal(5, 2)
  habitStreaks Json? @map("habit_streaks")
  
  summary String?
  recommendations String[]
  data Json?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@index([userId])
  @@index([date])
  @@index([type])
  @@map("insights")
}

// Push Subscriptions Table
model PushSubscription {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  endpoint String @unique
  p256dh String
  auth String
  deviceName String? @map("device_name")
  userAgent String? @map("user_agent")
  isActive Boolean @default(true) @map("is_active")
  lastUsed DateTime? @map("last_used")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  
  @@index([userId])
  @@index([isActive])
  @@map("push_subscriptions")
}

// Activity Logs Table (for auditing)
model ActivityLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  action String // create, update, delete, login, etc
  resourceType String? @map("resource_type")
  resourceId String? @map("resource_id") @db.Uuid
  changes Json?
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([resourceType])
  @@index([action])
  @@map("activity_logs")
}
